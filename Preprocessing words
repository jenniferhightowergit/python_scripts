# Dictionary of acronyms and symbols to expand
replacements = {
    r'\bmtr\b': 'meter',
    r'@': 'at'
}

def replace_acronyms(comment):
    for pattern, replacement in replacements.items():
        comment = re.sub(pattern, replacement, comment, flags=re.IGNORECASE)
    return comment





