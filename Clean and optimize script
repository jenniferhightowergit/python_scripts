df_raw = _load_file(args.input)
df_opt, _ = optimize_dataset(
    df_raw,
    numeric_method=args.numeric_method,
    cat_threshold=args.cat_threshold,
    exclude_cols=args.exclude,
)
_save_file(df_opt, args.output)
