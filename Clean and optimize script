# ── CLI entry point ────────────────────────────────────────────────────────────

def _load_file(path: str) -> pd.DataFrame:
p = Path(path)
ext = p.suffix.lower()
if ext == “.csv”:
return pd.read_csv(path)
elif ext in (”.xlsx”, “.xls”):
return pd.read_excel(path)
elif ext == “.parquet”:
return pd.read_parquet(path)
else:
raise ValueError(f”Unsupported file type: {ext}”)

def _save_file(df: pd.DataFrame, path: str) -> None:
p = Path(path)
ext = p.suffix.lower()
if ext == “.csv”:
df.to_csv(path, index=False)
elif ext in (”.xlsx”, “.xls”):
df.to_excel(path, index=False)
elif ext == “.parquet”:
df.to_parquet(path, index=False)
else:
raise ValueError(f”Unsupported output type: {ext}”)
print(f”Saved optimized dataset → {path}”)

if **name** == “**main**”:
parser = argparse.ArgumentParser(description=“Optimize a dataset for analytics.”)
parser.add_argument(”–input”,          required=True,  help=“Path to input file (csv/xlsx/parquet)”)
parser.add_argument(”–output”,         required=True,  help=“Path to output file”)
parser.add_argument(”–numeric-method”, default=“zscore”,
choices=[“zscore”, “minmax”, “none”],
help=“Numeric scaling method (default: zscore)”)
parser.add_argument(”–cat-threshold”,  type=float, default=0.5,
help=“Max unique-ratio to convert object col to category (default: 0.5)”)
parser.add_argument(”–exclude”,        nargs=”*”, default=[],
help=“Column names to skip”)
args = parser.parse_args()

