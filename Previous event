def get_30day_history(group):
    group = group.sort_values(["event_date", "event_priority"]).reset_index(drop=True)
    
    noncoms = (
        group[group["non_com_flag"] == 1]
        [["meter_num", "event_date", "event_type"]]
        .rename(columns={"event_date": "noncom_date", "event_type": "noncom_type"})
    )
    
    if noncoms.empty:
        return pd.DataFrame()
    
    all_events = group[["event_date", "event_type", "event_priority"]]
    
    # Small cross-join — safe because it's per meter only
    merged = noncoms.merge(all_events, how="cross")
    
    # Filter to 30-day lookback window
    merged = merged[
        (merged["event_date"] < merged["noncom_date"]) &
        (merged["event_date"] >= merged["noncom_date"] - pd.Timedelta(days=30))
    ]
    
    if merged.empty:
        return noncoms.rename(columns={"noncom_date": "event_date", "noncom_type": "event_type"})
    
    # Rank by date then priority within each non-com's window
    merged = merged.sort_values(["noncom_date", "event_date", "event_priority"])
    merged["rank"] = (
        merged.groupby("noncom_date")
        .cumcount() + 1          # cumcount on already-sorted df = date+priority rank
    )
    
    # Keep top 3 ranks only
    merged = merged[merged["rank"] <= 3]
    
    # Pivot ranks → columns
    pivot = merged.pivot_table(
        index=["meter_num", "noncom_date"],
        columns="rank",
        values=["event_type", "event_date"],
        aggfunc="first"
    )
    # Flatten: (event_type, 1) → prev_event_1_type
    pivot.columns = [
        f"prev_event_{rank}_{field.replace('event_', '')}"
        for field, rank in pivot.columns
    ]
    pivot = pivot.reset_index()
    
    # Merge history back onto non-com anchors
    result = noncoms.merge(pivot, on=["meter_num", "noncom_date"], how="left")
    return result.rename(columns={"noncom_date": "event_date", "noncom_type": "event_type"})


noncoms_with_history = (
    combined
    .groupby("meter_num", group_keys=False)
    .apply(get_30day_history)
