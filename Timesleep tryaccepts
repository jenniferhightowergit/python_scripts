
def _fetch_year_for_cells(
    cells: pd.DataFrame,
    year: int,
    overall_start: pd.Timestamp,
    overall_end: pd.Timestamp,
    lat_col: str,
    lon_col: str,
    verbose: bool,
) -> pd.DataFrame:
    year_start = max(pd.Timestamp(f"{year}-01-01"), overall_start).strftime("%Y-%m-%d")
    year_end = min(pd.Timestamp(f"{year}-12-31"), overall_end).strftime("%Y-%m-%d")

    rows: list[dict] = []
    n_batches = (len(cells) + OPEN_METEO_BATCH - 1) // OPEN_METEO_BATCH
    
    wait_times = [2, 5, 10, 30, 60, 120]  # same ladder as _open_meteo_request

    for b_idx, i in enumerate(range(0, len(cells), OPEN_METEO_BATCH), start=1):
        batch = cells.iloc[i : i + OPEN_METEO_BATCH]
        if verbose:
            print(f"  {year}: batch {b_idx}/{n_batches} ({len(batch)} cells)")

        # Retry this batch with escalating waits before giving up
        results = None
        for attempt, wait in enumerate(wait_times):
            try:
                results = _open_meteo_request(
                    batch[lat_col].tolist(),
                    batch[lon_col].tolist(),
                    year_start,
                    year_end,
                )
                break  # success, stop retrying
            except RuntimeError as e:
                print(f"  Batch {b_idx} failed (attempt {attempt+1}), waiting {wait}s before retry...")
                time.sleep(wait)

        if results is None:
            print(f"  Batch {b_idx} exhausted all retries, skipping.")
            continue

        for cell_row, result in zip(batch.itertuples(index=False), results):
            daily = result.get("daily", {}) or {}
            dates = pd.to_datetime(daily.get("time", []))
            tmax = daily.get("temperature_2m_max", []) or []
            tmin = daily.get("temperature_2m_min", []) or []
            precip = daily.get("precipitation_sum", []) or []
            for d, tx, tn, pr in zip(dates, tmax, tmin, precip):
                rows.append({
                    lat_col: getattr(cell_row, lat_col),
                    lon_col: getattr(cell_row, lon_col),
                    "date": d,
                    "tmax_f": tx,
                    "tmin_f": tn,
                    "precip_in": pr,
                })

        time.sleep(wait_times[0])  # always wait at least 2s between batches

    return pd.DataFrame(rows)




def _open_meteo_request(
    lats: list[float],
    lons: list[float],
    start_date: str,
    end_date: str,
    retries: int = 6,
) -> list[dict]:
    params = {
        "latitude": ",".join(f"{x:.4f}" for x in lats),
        "longitude": ",".join(f"{x:.4f}" for x in lons),
        "start_date": start_date,
        "end_date": end_date,
        "daily": "temperature_2m_max,temperature_2m_min,precipitation_sum",
        "temperature_unit": "fahrenheit",
        "precipitation_unit": "inch",
        "timezone": "America/Chicago",
    }
    
    wait_times = [2, 5, 10, 30, 60, 120]  # seconds to wait on each retry
    
    last_exc: Optional[Exception] = None
    for attempt in range(retries):
        try:
            r = requests.get(OPEN_METEO_URL, params=params, timeout=120,
                              headers={"User-Agent": DEFAULT_USER_AGENT}, verify=False)
            r.raise_for_status()
            data = r.json()
            if isinstance(data, dict):
                data = [data]
            return data
        except Exception as e:
            last_exc = e
            wait = wait_times[attempt] if attempt < len(wait_times) else 120
            print(f"  Request failed (attempt {attempt+1}), waiting {wait}s before retry...")
            time.sleep(wait)
    
    raise RuntimeError(
        f"Open-Meteo request failed after {retries} retries: {last_exc}"
    )
