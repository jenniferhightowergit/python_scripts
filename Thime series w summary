# Run this ONCE right after you load events_df
# Everything below will be fast after this

events_df["event_date"] = pd.to_datetime(events_df["event_date"])
events_df["month_period"] = events_df["event_date"].dt.to_period("M")
events_df["year"] = events_df["event_date"].dt.year
events_df["month"] = events_df["event_date"].dt.month

# Pre-aggregate your summary tables
monthly_outages = (
    events_df[events_df["event_type"] == "Outage"]
    .groupby("month_period")
    .size()
)

monthly_noncoms = (
    events_df["non_com_flag"]
    .groupby(events_df["month_period"])
    .sum()
)

# Year over year
yoy_outages = (
    events_df[events_df["event_type"] == "Outage"]
    .groupby(["year", "month"])
    .size()
    .unstack(level=0, fill_value=0)
)

yoy_noncoms = (
    events_df.groupby(["year", "month"])["non_com_flag"]
    .sum()
    .unstack(level=0, fill_value=0)
)

print("Done aggregating — charts will be fast from here")
print(f"Monthly outage periods: {len(monthly_outages)}")
print(f"Monthly non-com periods: {len(monthly_noncoms)}")


# Fast — only plotting small summary tables now
fig, (ax1, ax2) = plt.subplots(2, 1, figsize=(16, 8), sharex=True)

ax1.plot(monthly_outages.index.astype(str), monthly_outages.values,
         color="#fb923c", linewidth=2)
ax1.set_title("Monthly Outages", fontsize=12)
ax1.grid(alpha=0.2)

ax2.plot(monthly_noncoms.index.astype(str), monthly_noncoms.values,
         color="#38bdf8", linewidth=2)
ax2.set_title("Monthly Non-Coms", fontsize=12)
ax2.grid(alpha=0.2)

ax1.xaxis.set_major_locator(mticker.MultipleLocator(6))
plt.xticks(rotation=45, ha="right")
plt.tight_layout()
plt.show()

